<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hako.web.dao.blog.CommentDao">


	<resultMap type="com.hako.web.entity.blog.Blog_Comment"
		id="Result_Comment_Blog">
		<result property="pwd" column="PASSWORD" />
	</resultMap>

	<parameterMap type="com.hako.web.entity.blog.Blog_Comment"
		id="Param_Comment_Blog"></parameterMap>


	<!-- 댓글 등록 -->
	<insert id="insert" parameterMap="Param_Comment_Blog">
		INSERT INTO COMMENT_BLOG
		(REF,REF_COMMENT,COMMENT,
		USER_NAME,PASSWORD )
		values(#{ref},#{ref_comment},#{comment},#{user_name},#{pwd});
	</insert>

	<!-- 댓글 수정 -->
	<update id="update" parameterMap="Param_Comment_Blog">
		UPDATE COMMENT_BLOG SET
		COMMENT= #{comment}, USER_NAME=#{user_name} WHERE ID= ${id};
	</update>

	<!-- 댓글 삭제 -->
	<delete id="del" >
		DELETE FROM COMMENT_BLOG WHERE ID=${id};
	</delete>
	
	<!-- 댓글 리스트 반환  -->
	<select id="getList" resultMap="Result_Comment_Blog">
		SELECT *FROM COMMENT_BLOG WHERE REF =${num} ORDER BY CREATE_DATE DESC;
	</select>

	<!-- 댓글 반환 -->
	<select id="get" resultMap="Result_Comment_Blog">
		SELECT * FROM COMMENT_BLOG WHERE
		ID=${id};
	</select>

	<!-- 하위 댓글 수 반환 -->
	<select id="getRefCount"  resultType="int">
		SELECT COUNT(*)AS COUNT FROM COMMENT_BLOG WHERE
		REF_COMMENT=${ref};
	</select>
</mapper>